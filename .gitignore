# Build outputs
build/
build*/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
*.ninja
.ninja_*

# Generated board libraries and external SDK mirrors
/Core/
/Drivers/
/Middlewares/
/STM32CubeMX/
platforms/stm32/board/*/Core/
platforms/stm32/board/*/Drivers/
platforms/stm32/board/*/Middlewares/
platforms/stm32/board/*/STM32CubeMX/
*.hpmpc
sdkconfig
sdkconfig.old

# Vendored source trees are allowed when Clight maintains modified copies.
# Keep local/generated artifacts out of vendor.
vendor/**/build/
vendor/**/build*/
vendor/**/out/
vendor/**/Debug/
vendor/**/Release/
vendor/**/CMakeFiles/
vendor/**/cmake-build-*/
vendor/**/.git/
vendor/**/.idea/

# Binary artifacts
*.bin
*.elf
*.hex
*.map
*.a
*.o
*.obj
*.lib
*.dll
*.exe
*.pdb
*.ilk
*.zip

# Secrets and local credentials
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.*
credentials.*
id_rsa*
id_ed25519*

# Local/editor files
.vscode/
.idea/
*.user
*.log
*.tmp
*.bak
Thumbs.db
.DS_Store

# Python cache
__pycache__/
*.pyc

# Local reference documents not part of framework source
docs/reference/*.pdf
